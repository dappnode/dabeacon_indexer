# Copy to .env.test and fill in values for `scripts/run-integration-tests.sh`.
#
# Don't commit .env.test — it's already gitignored.

# Beacon node serving the target epoch. For finalized epochs > a few
# weeks old you'll need an archive node.
BEACON_URL=https://your-beacon-node.example/

# TEST_EPOCH and TEST_VALIDATORS are auto-randomised on each run when
# not set:
#   - TEST_EPOCH      → random pick from the last ~100 finalized epochs
#   - TEST_VALIDATORS → NUM_VALIDATORS random proposers for that epoch
#                       (proposers are guaranteed-active validators)
# Pin them here to reproduce a specific failure.
# TEST_EPOCH=12345
# TEST_VALIDATORS=1,2,3

# How many iterations to run with fresh random selections.
# ITERATIONS=5

# Size of the random validator pool when TEST_VALIDATORS is unset.
# Default 32 (one full epoch's proposer set). The bench sweeps subsets
# of this pool; override BENCH_SIZES=1,2,4,8 to control the sweep.
# NUM_VALIDATORS=32
# BENCH_SIZES=1,2,4,8,16,32

# Which test to run. Default runs both (equivalence + bench).
# TEST_FILTER=dense_sparse_attestation_rows_match
# TEST_FILTER=dense_vs_sparse_perf_bench

# Keep the test postgres container running after the test finishes.
# KEEP_DB=1

# Tracing filter. Default `dabeacon_indexer=info`.
# RUST_LOG=dabeacon_indexer=debug
